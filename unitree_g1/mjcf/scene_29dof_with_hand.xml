<mujoco model="g1_29dof scene">
  <include file="g1_29dof_with_hand.xml"/>

  <statistic center="0 0 0.5" extent="2.0"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

      <!-- Physical bench setup for bench press (collidable hitboxes). -->
      <body name="bench_setup" pos="0 0 0">
    <!-- Bench top: half-sizes (x, y, z). Top height = 0.56 + 0.04 = 0.60 -->
    <geom name="bench_top" type="box" pos="-0.02 0 0.56" size="0.68 0.18 0.04"
      rgba="0.20 0.20 0.22 1" friction="1.2 0.05 0.01"/>

    <!-- Bench legs -->
    <geom name="bench_leg_front" type="box" pos="0.48 0 0.26" size="0.05 0.05 0.30"
      rgba="0.16 0.16 0.18 1"/>
    <geom name="bench_leg_back" type="box" pos="-0.52 0 0.26" size="0.05 0.05 0.30"
      rgba="0.16 0.16 0.18 1"/>

    <!-- Simple rack (collidable but mostly visual context). -->
    <geom name="rack_left" type="box" pos="0.60 0.34 0.72" size="0.04 0.04 0.42"
      rgba="0.28 0.28 0.30 1"/>
    <geom name="rack_right" type="box" pos="0.60 -0.34 0.72" size="0.04 0.04 0.42"
      rgba="0.28 0.28 0.30 1"/>
    <geom name="rack_cross" type="box" pos="0.60 0 1.12" size="0.03 0.34 0.02"
      rgba="0.26 0.26 0.28 1"/>
      </body>
  </worldbody>
</mujoco>
